<?xml version="1.0" encoding="utf-8"?>
<!--
    Devices listed here cause Android to offer (or auto-launch) this app when plugged in.
    vendor-id / product-id are decimal integers.
    Omitting product-id matches all products from that vendor.

    Arduino SA             VID 0x2341 = 9025
    FTDI FT232R            VID 0x0403 PID 0x6001 = 1027 / 24577
    Silicon Labs CP210x    VID 0x10C4 PID 0xEA60 = 4292 / 60000
    WCH CH340/CH341        VID 0x1A86 PID 0x7523 = 6790 / 29987
    Prolific PL2303        VID 0x067B PID 0x2303 = 1659 / 8963
-->
<resources>
    <usb-device vendor-id="9025" />
    <usb-device vendor-id="1027"  product-id="24577" />
    <usb-device vendor-id="4292"  product-id="60000" />
    <usb-device vendor-id="6790"  product-id="29987" />
    <usb-device vendor-id="1659"  product-id="8963"  />
</resources>
